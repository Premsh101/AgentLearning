{
  "name": "bpsc-ai-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "seed:build": "tsx server/scripts/build-seed.ts",
    "server": "tsx watch server/src/index.ts",
    "start": "tsx server/src/index.ts",
    "typecheck:server": "tsc -p server/tsconfig.json",
    "build:server": "esbuild server/src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=server-dist/index.mjs --external:better-sqlite3 --banner:js=\"import{createRequire as __cr}from'node:module';const require=__cr(import.meta.url);\""
  },
  "dependencies": {
    "better-sqlite3": "^13.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.1"
  }
}
